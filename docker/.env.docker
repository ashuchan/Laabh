# Docker environment variables — copy this to .env.docker and fill in values

# Database
DB_PASSWORD=changeme_strong_password

# Angel One SmartAPI
ANGEL_ONE_API_KEY=
ANGEL_ONE_CLIENT_ID=
ANGEL_ONE_PASSWORD=
ANGEL_ONE_TOTP_SECRET=

# Anthropic Claude API
ANTHROPIC_API_KEY=

# Telegram notifications
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Whisper configuration
WHISPER_MODEL=large-v3
WHISPER_DEVICE=cuda

# General
LOG_LEVEL=INFO
